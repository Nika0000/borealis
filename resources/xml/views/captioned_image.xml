<brls:Box
    xmlns="http://borealisui.com/schema"
    xmlns:brls="http://borealisui.com/schema"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://borealisui.com/schema ../schema/borealis.xsd"
    width="auto"
    height="auto"
    axis="column"
    alignItems="center">

    <brls:Image
        id="image"
        width="auto"
        height="auto"
        focusable="true"
        marginBottom="20px" />

    <brls:Label
        id="label"
        width="auto"
        height="auto"
        horizontalAlign="center"
        textColor="@theme/captioned_image/caption" />

</brls:Box>